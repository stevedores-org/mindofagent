<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.stevedores.mindofagent</string>

    <key>ProgramArguments</key>
    <array>
        <string>__MINDOFAGENT_BIN__</string>
    </array>

    <!-- Launch at user login. -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart on crash, but don't restart on clean exit (so quitting
         from the menu actually quits). -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <!-- Interactive: app touches the user's GUI session, which is the
         whole point of MenuBarExtra. -->
    <key>ProcessType</key>
    <string>Interactive</string>

    <key>StandardOutPath</key>
    <string>/tmp/mindofagent.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/mindofagent.log</string>
</dict>
</plist>
